# Database Configuration (SQLite for development)
# DATABASE_URL=sqlite:./localconnect.db

# Session Secret (use a long random string in production)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Server Port
PORT=5000

# Environment
NODE_ENV=development

# CORS Settings (comma-separated origins)
CORS_ORIGINS=https://localconnect-git-main-zusy08s-projects.vercel.app,https://localconnect-1evv.onrender.com,http://localhost:5000,http://localhost:3000

# File Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Security Settings
BCRYPT_ROUNDS=10
SESSION_MAX_AGE=604800000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
